        rn_norm = (sv.get("room_number") or "").strip()
        rm_norm = normalize_text(sv.get("room_name") or "")
        
        candidates = []
        for i, it in enumerate(_all_ocr_items):
            if i in _used_box_indices:
                continue
            
            x1 = it["bbox"][0]
            y1 = it["bbox"][1]
            too_close = any(abs(x1 - ux) < 150 and abs(y1 - uy) < 150 for ux, uy in _used_box_coords)
            if too_close:
