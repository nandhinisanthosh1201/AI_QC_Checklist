            score = 0
            if vt_norm and len(tn) > 5:
                ts = room_name_similarity(tn, vt_norm)
                len_ratio = min(1.0, len(tn) / max(1, len(vt_norm)))
                if ts >= 70:
                    score = ts * len_ratio + 20  # Boost title matches
            
            if score == 0:
                if rn_norm and rn_norm in tn:
                    score = 80
                    if rm_norm and room_name_similarity(tn, rm_norm) > 60:
                        score = 90

            if score > 0:
                candidates.append((score, i, it["text"], it["bbox"]))
                
        if not candidates:
